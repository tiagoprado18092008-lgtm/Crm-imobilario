generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

enum UserRole {
  AGENCY_OWNER
  AGENCY_ADMIN
  LOCATION_ADMIN
  TEAM_LEADER
  CONSULTANT
  USER
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum RunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
}

model Agency {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  logoUrl  String?
  isActive Boolean @default(true)

  users       User[]
  automations Automation[]
  locations   Location[]
  settings    AgencySettings?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Location {
  id        String   @id @default(cuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id])
  name      String
  slug      String
  email     String?
  phone     String?
  address   String?
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  contacts      Contact[]
  opportunities Opportunity[]
  properties    Property[]
  tasks         Task[]
  appointments  Appointment[] @relation("AppointmentLocation")
  conversations Conversation[]
  campaigns     EmailCampaign[]
  forms         Form[]
  automations   Automation[]
  settings      LocationSettings?
  activityLogs  ActivityLog[]
  calendarEvents CalendarEvent[] @relation("CalendarEventLocation")

  @@unique([agencyId, slug])
}

model LocationSettings {
  id           String   @id @default(cuid())
  locationId   String   @unique
  location     Location @relation(fields: [locationId], references: [id])
  timezone     String   @default("Europe/Lisbon")
  locale       String   @default("pt-PT")
  currency     String   @default("EUR")
  workingHours Json     @default("{}")
  bookingPage  Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AgencySettings {
  id                 String   @id @default(cuid())
  agencyId           String   @unique
  agency             Agency   @relation(fields: [agencyId], references: [id])
  whitelabelEnabled  Boolean  @default(false)
  primaryColor       String   @default("#0f2553")
  defaultPermissions Json     @default("{}")
  securitySettings   Json     @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ActivityLog {
  id         String    @id @default(cuid())
  agencyId   String?
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])
  userId     String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  ip         String?
  createdAt  DateTime  @default(now())

  @@index([agencyId, createdAt])
  @@index([locationId, createdAt])
  @@index([userId, createdAt])
}

model User {
  id           String  @id @default(cuid())
  name         String
  email        String  @unique
  passwordHash String?
  googleId     String? @unique
  role         UserRole @default(CONSULTANT)
  phone        String?
  avatarUrl    String?
  isActive     Boolean  @default(true)
  onboardingCompleted Boolean @default(false)

  agencyId     String?
  agency       Agency?  @relation(fields: [agencyId], references: [id])

  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id])
  permissions  Json?

  supervisorId String?
  supervisor   User?   @relation("SupervisorSubAgents", fields: [supervisorId], references: [id])
  subAgents    User[]  @relation("SupervisorSubAgents")

  contacts      Contact[]
  opportunities Opportunity[]
  tasks         Task[]
  interactions  Interaction[]

  assignedConversations Conversation[] @relation("ConversationAssigned")
  sentMessages          Message[]      @relation("MessageSentBy")
  phoneNumbers          PhoneNumber[]
  appointments          Appointment[]
  campaigns             EmailCampaign[] @relation("CampaignCreatedBy")
  assignedForms         Form[]          @relation("FormAssignedTo")
  createdProperties     Property[]      @relation("PropertyCreator")
  coAssignedProperties  Property[]      @relation("PropertyCoAssigned")
  calendarIntegrations  CalendarIntegration[]
  calendarEvents        CalendarEvent[]
  calendarSlots         CalendarSlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id          String  @id @default(cuid())
  name        String
  email       String?
  phone       String?
  whatsapp    String?
  type        String  @default("LEAD")
  status      String  @default("NEW")
  source      String?
  notes       String?
  preferences String?

  assignedToId String
  assignedTo   User   @relation(fields: [assignedToId], references: [id])

  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id])

  budget_min    Float?
  budget_max    Float?
  interest_type String?
  interest_zones String?
  timeline      String?
  score         Int       @default(0)
  gdprConsent   Boolean   @default(false)
  gdprConsentDate DateTime?
  gdprConsentOrigin String?
  city          String?
  postalCode    String?
  nif           String?
  birthday      DateTime?
  lastContactedAt DateTime?

  // Campos dinâmicos por tipo
  selling_also     Boolean @default(false)  // Comprador que também quer vender
  needs_financing  Boolean @default(false)  // Comprador precisa de financiamento
  property_address String?                  // Morada do imóvel (Proprietário)
  asking_price     Float?                   // Preço pedido (Proprietário)
  sale_reason      String?                  // Razão da venda (Proprietário)
  buying_also      Boolean @default(false)  // Proprietário que também quer comprar
  commission       Float?                   // 5% × asking_price

  opportunities    Opportunity[]
  interactions     Interaction[]
  tasks            Task[]
  conversations    Conversation[]
  appointments     Appointment[]
  campaignRecipients EmailCampaignRecipient[]
  calendarEvents   CalendarEvent[]
  formSubmissions       FormSubmission[]
  automationEnrollments AutomationEnrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Property {
  id          String  @id @default(cuid())
  title       String
  description String?
  type        String
  status      String  @default("AVAILABLE")
  price       Float
  address     String
  area        Float?
  bedrooms    Int?
  bathrooms   Int?
  parking     Int?
  reference   String? @unique
  imageUrls   String  @default("[]")

  purpose           String  @default("SALE")
  lat               Float?
  lng               Float?
  district          String?
  energyCertificate String?
  yearBuilt         Int?
  condition         String?
  features          String  @default("[]")
  virtualTourUrl    String?
  tags              String  @default("[]")
  portalsPublished  String  @default("{}")
  commission        Float?
  contractStart     DateTime?
  contractEnd       DateTime?
  viewCount         Int     @default(0)

  createdById    String?
  createdBy      User?   @relation("PropertyCreator", fields: [createdById], references: [id])
  coAssignedToId String?
  coAssignedTo   User?   @relation("PropertyCoAssigned", fields: [coAssignedToId], references: [id])

  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id])

  opportunities Opportunity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Opportunity {
  id                String    @id @default(cuid())
  title             String
  stage             String    @default("LEAD_IN")
  value             Float?
  commission        Float?
  probability       Int       @default(50)
  source            String?
  expectedCloseDate DateTime?
  lostReason        String?
  notes             String?
  position          Int       @default(0)

  contactId    String
  contact      Contact   @relation(fields: [contactId], references: [id])
  propertyId   String?
  property     Property? @relation(fields: [propertyId], references: [id])
  assignedToId String
  assignedTo   User      @relation(fields: [assignedToId], references: [id])

  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id])

  // Campos dinâmicos por tipo (espelho do Contact)
  selling_also     Boolean @default(false)
  needs_financing  Boolean @default(false)
  property_address String?
  asking_price     Float?
  sale_reason      String?
  buying_also      Boolean @default(false)
  opp_commission   Float?  // comissão 5% calculada (renomeado para evitar conflito com commission existente)

  interactions Interaction[]
  tasks        Task[]
  appointments Appointment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Interaction {
  id        String  @id @default(cuid())
  type      String
  subject   String?
  body      String
  direction String  @default("OUTBOUND")

  contactId     String
  contact       Contact      @relation(fields: [contactId], references: [id])
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  createdById   String
  createdBy     User         @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("PENDING")
  priority    String    @default("MEDIUM")
  dueDate     DateTime?
  completedAt DateTime?

  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id])
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  assignedToId  String
  assignedTo    User         @relation(fields: [assignedToId], references: [id])

  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Conversation {
  id          String    @id @default(cuid())
  channel     String    // WHATSAPP, EMAIL, INSTAGRAM, INTERNAL
  externalId  String?   // thread ID / phone / email address
  status      String    @default("OPEN") // OPEN, RESOLVED, ARCHIVED

  contactId   String?
  contact     Contact?  @relation(fields: [contactId], references: [id])
  assignedToId String?
  assignedTo   User?    @relation("ConversationAssigned", fields: [assignedToId], references: [id])

  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id])

  messages    Message[]

  lastMessageAt DateTime @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AutomationRule {
  id          String   @id @default(cuid())
  name        String
  trigger     String   // NEW_LEAD, VISIT_SCHEDULED, MISSED_CALL, NO_RESPONSE_2H, LEAD_QUALIFIED, PROPOSAL_SENT
  isActive    Boolean  @default(true)
  actions     String   // JSON array of actions
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  logs        AutomationLog[]
}

model AutomationLog {
  id           String   @id @default(cuid())
  ruleId       String
  rule         AutomationRule @relation(fields: [ruleId], references: [id])
  contactId    String?
  trigger      String
  status       String   @default("SUCCESS") // SUCCESS, FAILED
  error        String?
  executedAt   DateTime @default(now())
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  direction      String   // INBOUND, OUTBOUND
  channel        String   // WHATSAPP, EMAIL, INSTAGRAM, INTERNAL, SMS
  content        String
  subject        String?  // for email
  status         String   @default("SENT") // SENT, DELIVERED, READ, FAILED
  externalId     String?  // message ID from WhatsApp/Meta

  sentById       String?
  sentBy         User?    @relation("MessageSentBy", fields: [sentById], references: [id])

  metadata       String?  // JSON string for extra data (attachments, etc.)
  createdAt      DateTime @default(now())
}

model PhoneNumber {
  id           String  @id @default(cuid())
  number       String  @unique
  friendlyName String?
  twilioSid    String
  status       String  @default("ACTIVE") // ACTIVE, RELEASED
  countryCode  String
  numberType   String  @default("LOCAL") // LOCAL, TOLLFREE, MOBILE
  capabilities String  @default("{\"voice\":true,\"sms\":true}")
  monthlyPrice Float   @default(1.15)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Appointment {
  id          String   @id @default(cuid())
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime
  status      String   @default("SCHEDULED") // SCHEDULED, CONFIRMED, CANCELLED, COMPLETED, NO_SHOW
  type        String   @default("VISIT") // VISIT, CALL, MEETING, OTHER

  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id])
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  assignedToId  String
  assignedTo    User         @relation(fields: [assignedToId], references: [id])

  locationId   String?
  appointmentLocation Location? @relation("AppointmentLocation", fields: [locationId], references: [id])

  reminderSent Boolean @default(false)
  notes        String?
  location     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailCampaign {
  id        String @id @default(cuid())
  name      String
  subject   String
  body      String // HTML content
  status    String @default("DRAFT") // DRAFT, SCHEDULED, SENDING, SENT, CANCELLED
  type      String @default("BROADCAST") // BROADCAST, SEQUENCE

  scheduledAt DateTime?
  sentAt      DateTime?
  sentCount   Int       @default(0)
  openCount   Int       @default(0)
  clickCount  Int       @default(0)

  // Target: JSON filter criteria (e.g., {"type":"LEAD","status":"NEW"})
  targetFilter String @default("{}")

  createdById String
  createdBy   User   @relation("CampaignCreatedBy", fields: [createdById], references: [id])

  locationId  String?
  location    Location? @relation(fields: [locationId], references: [id])

  recipients EmailCampaignRecipient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailCampaignRecipient {
  id         String @id @default(cuid())
  campaignId String
  campaign   EmailCampaign @relation(fields: [campaignId], references: [id])
  contactId  String
  contact    Contact @relation(fields: [contactId], references: [id])
  email      String
  status     String @default("PENDING") // PENDING, SENT, OPENED, CLICKED, BOUNCED, UNSUBSCRIBED
  sentAt     DateTime?
  openedAt   DateTime?
  createdAt  DateTime @default(now())
}

model Form {
  id          String @id @default(cuid())
  name        String
  description String?
  fields      String // JSON array of field definitions
  isActive    Boolean @default(true)
  submitAction String @default("CREATE_CONTACT") // CREATE_CONTACT, CREATE_LEAD
  thankYouMessage String @default("Obrigado! Entraremos em contacto em breve.")

  assignedToId String?
  assignedTo   User?   @relation("FormAssignedTo", fields: [assignedToId], references: [id])

  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id])

  submissions FormSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FormSubmission {
  id     String @id @default(cuid())
  formId String
  form   Form   @relation(fields: [formId], references: [id])
  data   String // JSON of submitted field values
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])
  ipAddress String?
  createdAt DateTime @default(now())
}

model Invitation {
  id          String    @id @default(cuid())
  email       String
  role        String    @default("CONSULTANT")
  token       String    @unique
  invitedById String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  locationId  String?
  permissions Json?
  agencyId    String?
}

model Automation {
  id          String   @id @default(cuid())
  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id])
  locationId  String?
  location    Location? @relation(fields: [locationId], references: [id])
  name        String
  description String?
  isActive    Boolean  @default(true)
  trigger     Json
  steps       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  enrollments AutomationEnrollment[]
  runs        AutomationRun[]
}

model AutomationEnrollment {
  id              String           @id @default(cuid())
  automationId    String
  automation      Automation       @relation(fields: [automationId], references: [id])
  contactId       String
  contact         Contact          @relation(fields: [contactId], references: [id])
  status          EnrollmentStatus @default(ACTIVE)
  currentStepId   String?
  waitingUntil    DateTime?
  waitingForEvent String?
  context         Json             @default("{}")
  startedAt       DateTime         @default(now())
  finishedAt      DateTime?

  runs AutomationRun[]
}

model AutomationRun {
  id           String                @id @default(cuid())
  automationId String
  automation   Automation            @relation(fields: [automationId], references: [id])
  enrollmentId String?
  enrollment   AutomationEnrollment? @relation(fields: [enrollmentId], references: [id])
  stepId       String
  status       RunStatus             @default(PENDING)
  input        Json
  output       Json?
  error        String?
  executedAt   DateTime              @default(now())
}

model CalendarIntegration {
  id               String    @id @default(cuid())
  userId           String
  provider         String    // "google" | "outlook"
  email            String
  accessToken      String    @db.Text
  refreshToken     String    @db.Text
  tokenExpiresAt   DateTime
  webhookChannelId  String?
  webhookResourceId String?
  webhookExpiry    DateTime?
  syncToken        String?
  deltaLink        String?
  lastSyncedAt     DateTime?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id])

  @@unique([userId, provider])
}

model CalendarEvent {
  id               String    @id @default(cuid())
  userId           String
  integrationId    String?
  externalId       String?
  externalProvider String?   // "google" | "outlook" | null
  title            String
  description      String?   @db.Text
  location         String?
  startAt          DateTime
  endAt            DateTime
  isAllDay         Boolean   @default(false)
  isRecurring      Boolean   @default(false)
  recurringRule    String?
  status           String    @default("confirmed")
  eventType        String    @default("other")
  color            String?
  attendees        Json?
  contactId        String?
  opportunityId    String?
  propertyId       String?
  meetLink         String?
  teamsLink        String?
  syncedAt         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id])
  contact          Contact?  @relation(fields: [contactId], references: [id])

  locationId       String?
  calendarLocation Location? @relation("CalendarEventLocation", fields: [locationId], references: [id])

  @@unique([userId, externalId, externalProvider])
  @@index([userId, startAt, endAt])
}

model CalendarSlot {
  id          String  @id @default(cuid())
  userId      String
  dayOfWeek   Int
  startTime   String
  endTime     String
  isAvailable Boolean @default(true)
  user        User    @relation(fields: [userId], references: [id])
}
